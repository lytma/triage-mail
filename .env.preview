# Preview profile — authoritative for lytma preview. Compose-internal service
# hostnames; lytma injects managed DATABASE_URL / REDIS_URL / self-URL at runtime
# (process env outranks these). No real cloud credentials required.

# Backing services (compose-internal; lytma overrides with managed instances)
DATABASE_URL=postgresql://triage:triage@postgres:5432/triage?schema=public
REDIS_URL=redis://redis:6379

# App self-URL — leave blank; derived from forwarded headers at request time.
APP_URL=
AUTH_URL=
AUTH_TRUST_HOST=true
AUTH_SECRET=preview-insecure-auth-secret-change-me-01234567890

# Token encryption (AES-256-GCM, 32 chars)
TOKEN_ENCRYPTION_KEY=preview0token0encryption0key01234

# Google OAuth (login) — blank in preview; login works via credentials + broker
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# lytma OAuth broker (injected by lytma in preview; do not hardcode)
OAUTH_BROKER_URL=
OAUTH_BROKER_SECRET=

# Microsoft OAuth — blank in preview
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT_ID=common

# Gmail mailbox connection — blank in preview (redirect URL is correct but flow can't complete)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_PUBSUB_TOPIC=
GMAIL_WEBHOOK_TOKEN=

# OpenAI — blank => deterministic stub classifier
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Stripe — blank => stub checkout/confirmation
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# Web Push VAPID — blank => ephemeral dev keypair (push best-effort in preview)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Analytics forwarding (optional) — blank => first-party only
ANALYTICS_PROVIDER_URL=

# Seeding — previews are demos
SEED_ON_BOOT=true
FORCE_RESEED=false

NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
