# ---------- Core services (injected by lytma in preview/prod) ----------
DATABASE_URL="postgresql://triage:triage@localhost:5432/triage?schema=public"
REDIS_URL="redis://localhost:6379"

# ---------- App self-URL (leave blank in preview; lytma injects forwarded host) ----------
APP_URL=
AUTH_URL=
AUTH_TRUST_HOST=true
# 32+ char secret for Auth.js session signing
AUTH_SECRET=

# ---------- Token encryption (AES-256-GCM, 32 chars) ----------
TOKEN_ENCRYPTION_KEY="0123456789abcdef0123456789abcdef"

# ---------- Google OAuth (login) — user fills these in for production ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# ---------- lytma OAuth broker (preview only — injected by lytma) ----------
OAUTH_BROKER_URL=
OAUTH_BROKER_SECRET=

# ---------- Microsoft OAuth (login + Outlook mailbox) ----------
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT_ID=common

# ---------- Gmail mailbox connection OAuth (may reuse GOOGLE_* ) ----------
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_PUBSUB_TOPIC=
GMAIL_WEBHOOK_TOKEN=

# ---------- OpenAI (stub mode when blank) ----------
OPENAI_API_KEY=
OPENAI_MODEL="gpt-4o-mini"

# ---------- Stripe (stub mode when blank) ----------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# ---------- Web Push VAPID (auto-generated stub if blank) ----------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@example.com"

# ---------- Analytics (optional hosted forwarding) ----------
ANALYTICS_PROVIDER_URL=

# ---------- Seeding ----------
SEED_ON_BOOT=false
FORCE_RESEED=false
